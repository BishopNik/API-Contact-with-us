PORT=3000
TELEGRAM_BOT_TOKEN=123456789:replace_me
TELEGRAM_CHAT_ID=-1001234567890

# JSON object. Add production domains before deployment.
# An empty array denies browser requests for that project.
PROJECT_ORIGINS={"a-house":["https://a-house.example"],"clean-space":["https://clean-space.example"],"led-flex":["https://led-flex.example"],"laser-clean":["https://laser-clean.example"]}

# Optional. Defaults are shown.
RATE_LIMIT_MAX=8
RATE_LIMIT_WINDOW_MS=60000
REQUEST_BODY_LIMIT_BYTES=16384
TRUST_PROXY=false
